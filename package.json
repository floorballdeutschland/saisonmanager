    "@angular/compiler-cli": "^22.0.1",
    "@schematics/angular": "^22.0.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/jasmine": "~6.0.0",
    "@types/node": "^25.9.3",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "angular-eslint": "^22.0.0",
    "eslint": "^10.5.0",
